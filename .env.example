POSTGRES_DB=energypulse
POSTGRES_USER=energypulse
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432


# Apache Kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_REGISTRATION_TOPIC=energypulse.home-registration.v1
KAFKA_TELEMETRY_TOPIC=energypulse.telemetry.v1

# Apache Ignite
IGNITE_CLIENT_PORT=10800
IGNITE_ADDRESSES=localhost:10800

# Web application
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional local demo data
DEMO_DATA_ENABLED=true
DEMO_CONTACT_EMAIL=demo@energypulse.local
