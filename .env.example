POSTGRES_DB=energypulse
POSTGRES_USER=energypulse
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432


# Apache Kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_REGISTRATION_TOPIC=energypulse.home-registration.v1
KAFKA_TELEMETRY_TOPIC=energypulse.telemetry.v1

# Apache Ignite
IGNITE_CLIENT_PORT=10800
IGNITE_ADDRESSES=localhost:10800

# Web application
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Gemini AI recommendations
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Notification processing
NOTIFICATION_PROCESSING_ENABLED=false
NOTIFICATION_POLLING_INTERVAL_MS=5000
NOTIFICATION_BATCH_SIZE=20

# SMTP email delivery
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_FROM=energypulse@example.com
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_CONNECTION_TIMEOUT_MS=5000
MAIL_TIMEOUT_MS=5000
MAIL_WRITE_TIMEOUT_MS=5000
MAIL_HEALTH_ENABLED=false
